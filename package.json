{
  "name": "thsr-app",
  "version": "1.2.0",
  "private": true,
  "type": "module",
  "homepage": "http://linyencheng.github.io/thsr-app",
  "devDependencies": {
    "@eslint/compat": "^2.0.5",
    "@eslint/js": "^9.39.4",
    "@preact/preset-vite": "^2.10.5",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/preact": "^3.2.4",
    "@testing-library/user-event": "^14.5.2",
    "@types/humps": "^2.0.6",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitest/coverage-istanbul": "4.1.5",
    "coverage-badges-cli": "^2.1.0",
    "eslint": "^9.39.4",
    "eslint-config-airbnb-extended": "^3.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "gh-pages": "^6.2.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.8.3",
    "sass-embedded": "^1.99.0",
    "typescript": "^5.7.2",
    "vite": "^7.0.0",
    "vite-plugin-svgr": "^4.3.0",
    "vitest": "4.1.5"
  },
  "dependencies": {
    "date-input-polyfill": "^2.14.0",
    "humps": "^2.0.1",
    "preact": "^10.29.1",
    "swr": "^2.2.5",
    "use-local-storage-state": "^19.5.0"
  },
  "pnpm": {
    "overrides": {
      "react": "npm:preact@^10.29.1",
      "react-dom": "npm:preact@^10.29.1"
    }
  },
  "scripts": {
    "start": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "coverage": "vitest run --coverage",
    "test": "vitest",
    "test:summary": "vitest run --coverage.enabled --reporter=junit --coverage.reporter=json-summary",
    "make-badges": "coverage-badges",
    "predeploy": "CI=false npm run build",
    "format": "prettier --write \"src/**/*.{js,scss}\"",
    "eslint": "eslint --ext .js,.jsx,.ts,.tsx src",
    "eslint:fix": "eslint --ext .js,.jsx,.ts,.tsx src --fix",
    "deploy": "gh-pages -b gh-pages -d build"
  }
}
